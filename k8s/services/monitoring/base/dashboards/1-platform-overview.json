{
  "uid": "platform-overview",
  "title": "Platform Overview",
  "description": "Health and throughput of all Quiz Master services at a glance",
  "tags": ["quizz-master", "overview"],
  "timezone": "browser",
  "refresh": "15s",
  "schemaVersion": 38,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "links": [
    { "title": "API Gateway", "url": "/d/api-gateway", "type": "link", "icon": "external link" },
    { "title": "Microservices", "url": "/d/microservices", "type": "link", "icon": "external link" },
    { "title": "Kafka", "url": "/d/kafka-monitoring", "type": "link", "icon": "external link" }
  ],
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Service Health",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "api-gateway",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(service_up{service=\"api-gateway\"}) by (service)",
          "legendFormat": "api-gateway",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "ms-user",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(service_up{service=\"ms-user\"}) by (service)",
          "legendFormat": "ms-user",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "ms-quizz-management",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(service_up{service=\"ms-quizz-management\"}) by (service)",
          "legendFormat": "ms-quizz-management",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "ms-session",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(service_up{service=\"ms-session\"}) by (service)",
          "legendFormat": "ms-session",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "ms-response",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "max(service_up{service=\"ms-response\"}) by (service)",
          "legendFormat": "ms-response",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Request Traffic",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Request Rate — all services (req/s)",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total[2m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Error Rate — 5xx per service (%)",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * (sum(rate(http_requests_total{status_code=~\"5..\"}[2m])) by (service) or (sum(rate(http_requests_total[2m])) by (service) * 0)) / sum(rate(http_requests_total[2m])) by (service)",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Latency",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "P50 Latency per service",
      "gridPos": { "x": 0, "y": 15, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[2m])) by (service, le))",
          "legendFormat": "{{service}} p50",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "P95 Latency per service",
      "gridPos": { "x": 8, "y": 15, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[2m])) by (service, le))",
          "legendFormat": "{{service}} p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "P99 Latency per service",
      "gridPos": { "x": 16, "y": 15, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[2m])) by (service, le))",
          "legendFormat": "{{service}} p99",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Active Requests & Node.js",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Active Requests",
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "http_active_requests",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Heap Used (MB)",
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "decmbytes", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "nodejs_heap_size_used_bytes / 1024 / 1024",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ]
    }
  ]
}
